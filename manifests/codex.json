{
  "version": 1,
  "platform": "codex",
  "managedRoot": "~/.codex",
  "sources": {
    "openspec": {
      "type": "npm",
      "package": "@fission-ai/openspec",
      "version": "latest",
      "install": "npm install -g @fission-ai/openspec@latest"
    },
    "superpowers": {
      "type": "upstream-install-doc",
      "url": "https://raw.githubusercontent.com/obra/superpowers/refs/heads/main/.codex/INSTALL.md",
      "notes": "Forgevia relies on upstream superpowers installation, then overlays managed customizations."
    }
  },
  "managedAssets": [
    {
      "id": "openspec-config-prompts",
      "source": "assets/openspec/dist/core/config-prompts.js",
      "target": "<openspec-root>/dist/core/config-prompts.js",
      "owner": "forgevia",
      "kind": "openspec-override",
      "upstream": "openspec"
    },
    {
      "id": "openspec-propose-workflow",
